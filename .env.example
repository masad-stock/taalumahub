# DEMO_MODE: Set to "true" to bypass real M-Pesa and use instant demo payments.
DEMO_MODE="true"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=""

# APP_URL: The URL where this app is hosted (required for M-Pesa callbacks)
APP_URL="http://localhost:3000"

# M-Pesa Daraja API Credentials
# Get these from Safaricom Daraja Portal: https://developer.safaricom.co.ke/
# These are REQUIRED when DEMO_MODE is false
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
